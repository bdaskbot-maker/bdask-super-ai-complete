# BDAsk Super AI Environment Configuration

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Workspace (where file operations are allowed)
WORKSPACE_ROOT=/path/to/your/workspace

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# MongoDB (optional - for conversation persistence)
MONGODB_URI=mongodb://localhost:27017/bdask_super_ai

# Web Search API (Serper.dev - get free tier at serper.dev)
SERPER_API_KEY=your_serper_api_key

# Security
MAX_ITERATIONS=50
ENABLE_BASH=true
BASH_TIMEOUT=120000
