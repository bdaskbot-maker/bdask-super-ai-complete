# BDAsk Super AI Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# REQUIRED: OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
# ============================================
OPENAI_API_KEY=sk-...

# ============================================
# Available AI Models (via OpenAI API):
# Tier 1 - AI Agent (Foundation):
# - gpt-4o: Most capable, best for complex tasks
# - gpt-4-turbo: Faster, good balance
# - gpt-3.5-turbo: Budget option
#
# Tier 2 - Super Agent (Enterprise):
# Uses same models with advanced planning/memory
#
# Tier 3 - Dev Agent (Development):
# Uses same models with full-stack capabilities
# ============================================
OPENAI_DEFAULT_MODEL=gpt-4o

# ============================================
# Optional: Backend Server Configuration
# (Only needed if running the Express backend)
# ============================================
PORT=5000
NODE_ENV=development

# Workspace (where file operations are allowed)
WORKSPACE_ROOT=/path/to/your/workspace

# MongoDB (for conversation persistence)
# MONGODB_URI=mongodb://localhost:27017/bdask_super_ai

# Web Search API (Serper.dev - get free tier at serper.dev)
# SERPER_API_KEY=your_serper_api_key

# Security
MAX_ITERATIONS=50
ENABLE_BASH=true
BASH_TIMEOUT=120000
