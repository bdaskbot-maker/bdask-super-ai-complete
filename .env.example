# BDAsk Super AI Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# REQUIRED: Google Gemini API Key
# Get your free key from: https://aistudio.google.com/apikey
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini Model (default: gemini-1.5-flash)
# Available models: gemini-1.5-flash, gemini-1.5-pro, gemini-pro
GEMINI_MODEL=gemini-1.5-flash

# ============================================
# Optional: Backend Server Configuration
# (Only needed if running the Express backend)
# ============================================
PORT=5000
NODE_ENV=development

# Workspace (where file operations are allowed)
WORKSPACE_ROOT=/path/to/your/workspace

# MongoDB (for conversation persistence)
# MONGODB_URI=mongodb://localhost:27017/bdask_super_ai

# Web Search API (Serper.dev - get free tier at serper.dev)
# SERPER_API_KEY=your_serper_api_key

# Security
MAX_ITERATIONS=50
ENABLE_BASH=true
BASH_TIMEOUT=120000
