# BDAsk Super AI Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# REQUIRED: NVIDIA API Key
# Get your key from: https://build.nvidia.com/
# ============================================
NVIDIA_API_KEY=your_nvidia_api_key_here

# ============================================
# Available AI Models (via NVIDIA API):
# - kimi-k2.5: Moonshot AI Kimi K2.5 (Advanced reasoning)
# - nemotron-super: NVIDIA Nemotron Super 120B (Most powerful)
# - gemma-4: Google Gemma 4 31B (Efficient)
# - glm-5: Z-AI GLM 5.1 (Powerful language model)
# ============================================

# ============================================
# Optional: Backend Server Configuration
# (Only needed if running the Express backend)
# ============================================
PORT=5000
NODE_ENV=development

# Workspace (where file operations are allowed)
WORKSPACE_ROOT=/path/to/your/workspace

# MongoDB (for conversation persistence)
# MONGODB_URI=mongodb://localhost:27017/bdask_super_ai

# Web Search API (Serper.dev - get free tier at serper.dev)
# SERPER_API_KEY=your_serper_api_key

# Security
MAX_ITERATIONS=50
ENABLE_BASH=true
BASH_TIMEOUT=120000
